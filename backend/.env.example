# Database
DATABASE_URL=postgresql+asyncpg://sweeps:sweeps@localhost:5432/sweeps

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# App
SECRET_KEY=change-me-to-a-long-random-string
ENCRYPTION_KEY=change-me-32-byte-base64-fernet-key
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# OpenRouteService (geocoding + directions)
ORS_API_KEY=your_openrouteservice_api_key

# Gmail polling interval (seconds)
GMAIL_POLL_INTERVAL=120

# JWT expiry (minutes)
JWT_EXPIRE_MINUTES=10080
